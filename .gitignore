# ==========================================================
# ProyectoVacaciones - .gitignore
# Compatible con Windows, macOS y Linux
# Preparado para Python, Java, Node.js, Docker y VS Code
# ==========================================================

# ==========================================================
# SISTEMA OPERATIVO
# ==========================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ==========================================================
# EDITORES E IDEs
# ==========================================================

# Visual Studio Code
.vscode/

# JetBrains (IntelliJ, PyCharm, Android Studio...)
.idea/
*.iml

# Visual Studio
.vs/

# Eclipse
.project
.classpath
.settings/

# ==========================================================
# LOGS
# ==========================================================

*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================
# VARIABLES DE ENTORNO
# ==========================================================

.env
.env.*
!.env.example

# ==========================================================
# PYTHON
# ==========================================================

__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
env/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/

.coverage
coverage.xml
htmlcov/

dist/
build/
*.egg-info/

# ==========================================================
# NODE.JS
# ==========================================================

node_modules/

npm-cache/

.pnpm-store/

.next/
.nuxt/

dist/

coverage/

# ==========================================================
# JAVA / KOTLIN
# ==========================================================

*.class
*.jar
*.war
*.ear

.gradle/

build/
out/

# ==========================================================
# ANDROID
# ==========================================================

local.properties
captures/

.cxx/

# ==========================================================
# DOCKER
# ==========================================================

*.pid

# ==========================================================
# BASES DE DATOS LOCALES
# ==========================================================

*.sqlite
*.sqlite3
*.db

# ==========================================================
# ARCHIVOS TEMPORALES
# ==========================================================

tmp/
temp/

*.tmp
*.swp
*.swo

# ==========================================================
# ARCHIVOS COMPRIMIDOS
# ==========================================================

*.zip
*.rar
*.7z
*.tar
*.gz

# ==========================================================
# CACHE
# ==========================================================

.cache/

# ==========================================================
# REPORTES
# ==========================================================

reports/

# ==========================================================
# SECRETOS
# ==========================================================

secrets/
credentials/

*.pem
*.key

# ==========================================================
# MANTENER ESTAS CARPETAS EN EL REPOSITORIO
# (aunque estén vacías, usando un archivo .gitkeep)
# ==========================================================

#!logs/.gitkeep
#!temp/.gitkeep